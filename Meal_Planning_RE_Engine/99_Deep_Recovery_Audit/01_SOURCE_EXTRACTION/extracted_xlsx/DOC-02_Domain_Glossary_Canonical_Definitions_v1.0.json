     "Meal Class",
     "Behavioral class/category of meal eaten regularly; dish is an instance.",
     "Plan classes before dishes.",
     "DOC-05, DOC-12"
    ],
    [
     "Primary Meal Class",
     "Main class eaten by majority household for a slot.",
     "Used in weekly class plan primary columns.",
     "DOC-06, DOC-13"
    ],
    [
     "Secondary/Tertiary Class",
     "Compatible fallback/variety class for a slot.",
     "Used when primary blocked or for carousel variety.",
     "DOC-12, DOC-14"
    ],
    [
     "Add-on Component",
     "Extra member-specific component for infant/toddler/elderly/diabetic/etc.",
     "Never replaces family primary meal unless household is only that segment.",
     "DOC-04, DOC-06"
    ],
    [
     "Main Cohort",
     "Small user-facing top-level cohort.",
     "Keep to 4-5 choices in onboarding.",
     "DOC-03, DOC-10"
    ],
    [
     "Sub-cohort",
     "Second-level user-facing segment after main cohort.",
     "Maps to backend persona.",
     "DOC-03"
    ],
    [
