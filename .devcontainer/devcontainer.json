{
  "name": "foofoo",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:22",
  "secrets": {
    "SUPABASE_URL": {
      "description": "Supabase dev project URL (Mumbai)",
      "documentationUrl": "https://supabase.com/dashboard/project/ufgfznpqixplcbhmsqqw/settings/api"
    },
    "SUPABASE_ANON_KEY": {
      "description": "Supabase anon/public key — respects RLS",
      "documentationUrl": "https://supabase.com/dashboard/project/ufgfznpqixplcbhmsqqw/settings/api"
    },
    "SUPABASE_SERVICE_ROLE_KEY": {
      "description": "Supabase service role key — bypasses RLS, test teardown only",
      "documentationUrl": "https://supabase.com/dashboard/project/ufgfznpqixplcbhmsqqw/settings/api"
    }
  },
  "postCreateCommand": "cd foofoo-tests && npm install",
  "remoteEnv": {
    "SUPABASE_URL": "${localEnv:SUPABASE_URL}",
    "SUPABASE_ANON_KEY": "${localEnv:SUPABASE_ANON_KEY}",
    "SUPABASE_SERVICE_ROLE_KEY": "${localEnv:SUPABASE_SERVICE_ROLE_KEY}"
  }
}
