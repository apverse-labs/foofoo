# foofoo-tests — Environment Variables
# Copy this file to .env.test and fill in your values.
# .env.test is gitignored — never commit real keys.
#
# ⚠️  USE THE DEV SUPABASE PROJECT ONLY — NEVER PRODUCTION KEYS.
# Integration tests and the persona runner write and delete data.
# Running against production will corrupt live user data.
#
# Unit tests (npm run test:unit) do NOT need any of these.
# Integration tests (npm run test:integration) need all required fields.
# Persona runner (npm run personas) needs all required fields.
#
# Where to find values:
#   Supabase Dashboard → Project Settings → API
#   Dev project: https://supabase.com/dashboard/project/ufgfznpqixplcbhmsqqw/settings/api

# ── Supabase Dev Project ──────────────────────────────────────────────────────
# Public URL for the dev Supabase project
SUPABASE_URL=https://your-dev-project-ref.supabase.co

# Anon/public key — respects Row Level Security
SUPABASE_ANON_KEY=your-dev-anon-key-here

# Service role key — bypasses RLS (used only in test setup/teardown helpers)
# ⚠️  Never use the production service role key here.
SUPABASE_SERVICE_ROLE_KEY=your-dev-service-role-key-here

# Edge Functions base URL (for integration tests that invoke functions directly)
SUPABASE_FUNCTIONS_URL=https://your-dev-project-ref.supabase.co/functions/v1

# ── Test Configuration ────────────────────────────────────────────────────────
# Email domain used when creating test user accounts (avoids polluting real inboxes)
TEST_EMAIL_DOMAIN=foofoo.dev

# Timeout in milliseconds for plan generation calls in integration tests
PLAN_GEN_TIMEOUT_MS=5000
