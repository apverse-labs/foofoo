# foofoo-tests environment template — copy to .env.test and fill in.
# .env.test is gitignored. Never commit real keys.
# In CI these are injected as GitHub Actions secrets (same names).

# ─── MVP production (original FooFoo app — main/develop branch) ──────────────
SUPABASE_URL=https://ufgfznpqixplcbhmsqqw.supabase.co          # foofoo-mvp
SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...     # for MVP RLS/DPDP tests

# ─── RE staging (Recommendation Engine — apverse-labs-RE branch) ─────────────
SUPABASE_STAGING_URL=https://kwypxyqxojauhiehuirz.supabase.co  # foofoo-staging
SUPABASE_STAGING_ANON_KEY=...
SUPABASE_STAGING_SERVICE_ROLE_KEY=...   # for RE persona creation / RLS / DPDP / seed counts

# App uses EXPO_PUBLIC_ prefixed names locally — globalSetup maps them automatically.
# Either form works; GitHub Secrets form (above) takes priority.
# EXPO_PUBLIC_SUPABASE_RE_URL=https://kwypxyqxojauhiehuirz.supabase.co
# EXPO_PUBLIC_SUPABASE_RE_ANON_KEY=...

# ─── Target selection ────────────────────────────────────────────────────────
QA_TARGET=re-staging              # re-staging | mvp-prod
