# foofoo-tests — environment variables for integration + persona tests
# Copy this file to .env.test and fill in your values.
# .env.test is gitignored — never commit real keys.
#
# Required for: integration tests, persona runner
# Unit tests do NOT need any of these.
#
# ⚠️  ufgfznpqixplcbhmsqqw is DEP-PRODUCTION (live user data, see SYSTEM_STATE.md).
#     It is NOT a dev project — never put it in SUPABASE_URL. foofoo-staging
#     (kwypxyqxojauhiehuirz) carries the full schema (CKPT-001 + RE tables) and
#     is the only sanctioned test target; config/targets.ts falls back to it
#     automatically if SUPABASE_URL is left unset.

# foofoo-staging project URL (Mumbai) — safe test target
SUPABASE_URL=https://kwypxyqxojauhiehuirz.supabase.co

# Anon/public key — respects Row Level Security
# Found in: Supabase Dashboard → Project Settings → API → Project API keys → anon public
SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — bypasses RLS (used only in test helpers, never in app code)
# Found in: Supabase Dashboard → Project Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
