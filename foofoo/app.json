{
  "expo": {
    "name": "Foofoo",
    "slug": "foofoo",
    "owner": "apverse-labs",
    "version": "1.0.0",
    "description": "AI-powered meal decision assistant for India. Every morning, see a personalised Breakfast / Lunch / Dinner plan. Swipe to browse, lock what you love, cook or order.",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "foofoo",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D6A4F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.foofoo.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#2D6A4F"
      },
      "package": "com.foofoo.app",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png",
      "name": "Foofoo",
      "shortName": "Foofoo",
      "description": "Your AI meal planner",
      "themeColor": "#2D6A4F",
      "backgroundColor": "#2D6A4F",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2D6A4F"
        }
      ],
      "expo-image",
      [
        "onesignal-expo-plugin",
        {
          "mode": "development"
        }
      ],
      "expo-localization"
    ],
    "extra": {
      "oneSignalAppId": "83860a1b-1cb9-4982-8a61-d8acc2c4680a",
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "OneSignalNotificationServiceExtension",
                  "bundleIdentifier": "com.foofoo.app.OneSignalNotificationServiceExtension",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.foofoo.app.onesignal"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "407c854c-bb29-4ca5-9193-ce80955b5c49"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
