# FooFoo — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.
#
# All variables prefixed EXPO_PUBLIC_ are bundled into the client app.
# Do NOT put secrets (service role keys, API secrets) here — those go in Supabase Vault.
#
# Where to find values:
#   Supabase: https://supabase.com/dashboard/project/ufgfznpqixplcbhmsqqw/settings/api
#   OneSignal: https://dashboard.onesignal.com → Your App → Settings → Keys & IDs
#   PostHog:   https://us.posthog.com → Project Settings → Project API Key
#   Sentry:    https://sentry.io → Project → Settings → Client Keys (DSN)

# ── Supabase ─────────────────────────────────────────────────────────────────
# Public URL for the Supabase project (safe to expose client-side)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key — enforces Row Level Security (safe to expose client-side)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── OneSignal ─────────────────────────────────────────────────────────────────
# OneSignal App ID — must match extra.oneSignalAppId in app.json
# Current value: 83860a1b-1cb9-4982-8a61-d8acc2c4680a
# NOTE: Also hardcoded in app.json for the onesignal-expo-plugin build step.
# Keep both values in sync when switching between dev/prod OneSignal apps.
EXPO_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id-here

# ── PostHog Analytics ─────────────────────────────────────────────────────────
EXPO_PUBLIC_POSTHOG_KEY=your-posthog-project-key-here
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Sentry Error Tracking ────────────────────────────────────────────────────
# Leave blank in local dev to disable Sentry (or set EXPO_PUBLIC_SENTRY_DEV_ENABLED=true)
EXPO_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id
EXPO_PUBLIC_SENTRY_DEV_ENABLED=false
